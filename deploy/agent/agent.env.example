# ERA XDR agent environment (copy to /etc/era-one/agent.env)
ERA_PRODUCTION=1
ERA_GATEWAY_ADDR=http://ingest.corp:50051
ERA_CONTROL_PLANE_URL=http://control.corp:8090
ERA_AUDIT_LOG=/var/log/audit/audit.log
# mTLS (optional):
# ERA_TLS_CA=/etc/era-one/ca.crt
# ERA_TLS_CLIENT_CERT=/etc/era-one/agent.crt
# ERA_TLS_CLIENT_KEY=/etc/era-one/agent.key
